# fastlane snapshot — localized App Store screenshots, generated by
# driving the app through the offline `--ui-loopback` UI-test harness.
# Output lands in fastlane/screenshots/ (git-ignored — regenerate on demand).

# iPhone 17 Pro Max is the 6.9" display Apple requires for App Store
# screenshots. Add more device names here if their simulator runtimes are
# installed (e.g. a 6.5" device) — each one multiplies runtime.
devices(["iPhone 17 Pro Max"])

# The app is fully localized (see Localizable.xcstrings). Capture both.
languages(["en-US", "ru"])

scheme("OnymIOS")

# Only the dedicated screenshot flow — not the whole UI-test suite.
only_testing(["OnymIOSUITests/ScreenshotUITests"])

output_directory("./fastlane/screenshots")
clear_previous_screenshots(true)

# Clean 9:41 / full-battery status bar for App Store presentation.
override_status_bar(true)

# Keep derived data out of the repo (project convention).
derived_data_path("/tmp/onym-ios-snapshot-dd")

concurrent_simulators(false)
stop_after_first_error(true)
number_of_retries(1)
