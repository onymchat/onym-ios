default_platform(:ios)

platform :ios do
  desc "Ad-hoc IPA for GitHub Release"
  lane :release do
    setup_ci(force: true)

    match(
      type: "adhoc",
      app_identifier: ["app.onym.ios"],
      readonly: true
    )

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "OnymIOS.xcodeproj",
      team_id: ENV['MATCH_TEAM_ID'],
      code_sign_identity: "Apple Distribution",
      targets: ["OnymIOS"],
      profile_name: "match AdHoc app.onym.ios"
    )

    gym(
      project: "OnymIOS.xcodeproj",
      scheme: "OnymIOS",
      configuration: "Release",
      destination: "generic/platform=iOS",
      export_method: "ad-hoc",
      archive_path: "build/ios/adhoc/OnymIOS.xcarchive",
      export_options: {
        signingStyle: "manual",
        teamID: ENV['MATCH_TEAM_ID'],
        provisioningProfiles: {
          "app.onym.ios" => "match AdHoc app.onym.ios"
        }
      },
      xcargs: "COMPILER_INDEX_STORE_ENABLE=NO DEVELOPMENT_TEAM='#{ENV['MATCH_TEAM_ID']}'",
      output_directory: "build/ios/adhoc",
      output_name: "OnymIOS.ipa"
    )
  end

  desc "Generate localized App Store screenshots via the UI-test harness"
  desc ""
  desc "Drives the app through fastlane snapshot (see fastlane/Snapfile):"
  desc "the ScreenshotUITests flow runs on the offline --ui-loopback"
  desc "harness, seeds a group + conversation, and captures every screen"
  desc "in each configured language. Output → fastlane/screenshots/"
  desc "(git-ignored). Upload separately with the deliver lane once you're"
  desc "happy (set skip_screenshots: false there)."
  lane :screenshots do
    capture_ios_screenshots
  end

  desc "Upload App Store metadata to App Store Connect (no binary, no screenshots)"
  desc ""
  desc "Reads an App Store Connect API key from the environment:"
  desc "  ASC_KEY_ID              — the key's Key ID"
  desc "  ASC_ISSUER_ID           — your App Store Connect Issuer ID"
  desc "  ASC_KEY_PATH            — path to the .p8 file            (or…)"
  desc "  ASC_KEY_CONTENT         — the .p8 contents, inline        (use in CI)"
  desc "  ASC_KEY_CONTENT_BASE64  — 'true' if ASC_KEY_CONTENT is base64-encoded"
  desc "  ASC_APP_VERSION         — optional; the version whose metadata to edit"
  desc ""
  desc "Metadata lives in fastlane/metadata/ (committed). Screenshots are"
  desc "out of scope and skipped; no binary is uploaded and nothing is"
  desc "submitted for review — this only pushes the listing text."
  lane :upload_metadata do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV["ASC_KEY_PATH"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "app.onym.ios",
      app_version: ENV["ASC_APP_VERSION"],
      metadata_path: "./fastlane/metadata",
      # Text-only push: no binary, no screenshots, no review submission.
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      # Non-interactive: don't open the HTML preview / prompt.
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end

  desc "Upload App Store metadata AND screenshots to App Store Connect"
  desc ""
  desc "Same App Store Connect API key env vars as upload_metadata:"
  desc "  ASC_KEY_ID / ASC_ISSUER_ID / ASC_KEY_PATH (or ASC_KEY_CONTENT"
  desc "  [+ ASC_KEY_CONTENT_BASE64]) / optional ASC_APP_VERSION."
  desc ""
  desc "Pushes the committed metadata (fastlane/metadata) plus the"
  desc "generated screenshots (fastlane/screenshots — run the screenshots"
  desc "lane first). No binary is uploaded and nothing is submitted for"
  desc "review."
  lane :upload_all do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("ASC_KEY_ID"),
      issuer_id: ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV["ASC_KEY_PATH"],
      key_content: ENV["ASC_KEY_CONTENT"],
      is_key_content_base64: ENV["ASC_KEY_CONTENT_BASE64"] == "true",
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "app.onym.ios",
      app_version: ENV["ASC_APP_VERSION"],
      metadata_path: "./fastlane/metadata",
      screenshots_path: "./fastlane/screenshots",
      # Push listing text + screenshots; no binary, no review submission.
      skip_binary_upload: true,
      skip_metadata: false,
      skip_screenshots: false,
      overwrite_screenshots: true,
      # Non-interactive: don't open the HTML preview / prompt.
      force: true,
      run_precheck_before_submit: false,
      precheck_include_in_app_purchases: false,
      submit_for_review: false
    )
  end
end
