# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Generated Xcode project — project.yml is the source of truth, run
# ./generate-xcodeproj.sh after pulling. Tracking pbxproj costs us a
# merge-conflict tax on every multi-author PR with no upside since
# xcodegen is fast.
*.xcodeproj/
*.xcworkspace/

# Xcode user state
xcuserdata/
*.xcuserstate
*.xcscmblueprint
*.xccheckout
*.moved-aside
*.pbxuser
!default.pbxuser
*.mode1v3
!default.mode1v3
*.mode2v3
!default.mode2v3
*.perspectivev3
!default.perspectivev3

# Xcode build products and indexes
build/
DerivedData/
*.hmap
*.ipa
*.dSYM/
*.dSYM.zip
*.xcarchive/

# Swift Package Manager
.build/
Packages/
.swiftpm/xcode/package.xcworkspace/
.swiftpm/xcode/xcuserdata/
.swiftpm/configuration/registries.json
.swiftpm/configuration/security/

# Dependency manager build output
Carthage/Build/
Pods/

# CocoaPods local state
Podfile.lock.tmp

# Fastlane generated output
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/screenshots/**/*.png

# Bundler (Fastlane gem dependency tree)
vendor/
.bundle/

# App signing material and local secrets
*.mobileprovision
*.provisionprofile
*.cer
*.p12
*.pem
.env
.env.*
!.env.example
!.env.sample

# Relayer Bearer auth token — bundled at build time, never committed.
# Local dev: copy RelayerSecrets.example.json → RelayerSecrets.json and
# paste the dev token. Release CI: workflow writes this file from the
# repo's `RELAYER_AUTH_TOKEN` secret before xcodegen runs.
Resources/RelayerSecrets.json

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Claude Code per-session worktrees + agent scratch state. Each chunk
# is developed in its own `.claude/worktrees/<name>/` checkout that
# gets wiped after its PR merges. Nothing in this directory is build
# input or the source of truth.
.claude/
