# Normalize text files across platforms.
* text=auto

# Source and project files should stay diffable.
*.swift text eol=lf
*.h text eol=lf
*.m text eol=lf
*.mm text eol=lf
*.c text eol=lf
*.cc text eol=lf
*.cpp text eol=lf
*.hpp text eol=lf
*.metal text eol=lf
*.modulemap text eol=lf
*.pbxproj text eol=lf
*.xcconfig text eol=lf
*.plist text eol=lf
*.entitlements text eol=lf
*.storyboard text eol=lf
*.xib text eol=lf
*.strings text eol=lf
*.stringsdict text eol=lf
*.xcstrings text eol=lf
*.json text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.sh text eol=lf
*.rb text eol=lf
*.py text eol=lf

# Images and design assets.
*.png filter=lfs diff=lfs merge=lfs -text
